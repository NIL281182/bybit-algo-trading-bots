# Bybit API Keys для торговых ботов
# Заполните и переименуйте файл в .env
# Используйте Testnet ключи для тестирования!
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Telegram Alerts (опционально)
# 1. Напишите @BotFather в Telegram → /newbot → получите BOT_TOKEN
# 2. Напишите @userinfobot → получите CHAT_ID
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
